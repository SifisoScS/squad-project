ANTHROPIC_API_KEY=your-key-here

# Corporate network SSL fix (Zscaler/proxy intercepts HTTPS).
# Set SSL_NO_VERIFY=true for a quick bypass on a trusted network, OR
# set SSL_CERT_FILE to the path of your corporate CA PEM bundle for a proper fix.
SSL_NO_VERIFY=true
# SSL_CERT_FILE=C:\path\to\corporate-ca.pem

# ── Model / Agent ──────────────────────────────────────────────────────────────
# Model ID used by all agents. Override per-agent via the model= parameter.
SQUAD_MODEL=claude-sonnet-4-6
MAX_ITERATIONS=15
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0
MAX_HISTORY_TURNS=20

# ── Build Pipeline ─────────────────────────────────────────────────────────────
MAX_BUILD_SPRINTS=10
MAX_REJECTIONS=2
# Maximum seconds a single build may run before it is force-failed.
BUILD_TIMEOUT_SECONDS=1800
# Root directory for generated project workspaces.
WORKSPACE_ROOT=workspace

# ── API Security ───────────────────────────────────────────────────────────────
# Set API_SECRET_KEY to require Bearer token authentication on mutating routes
# (POST /build, DELETE /build/{id}, DELETE /workspace/{name}, POST /skill/invoke).
# Leave empty to disable auth — safe for personal local use only.
# Contact Tech-AI-Engineering@derivco.com before exposing this service internally.
API_SECRET_KEY=

# Comma-separated list of allowed CORS origins for browser clients.
ALLOWED_ORIGINS=http://localhost:8000

# ── Logging ────────────────────────────────────────────────────────────────────
# Python logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Memory ─────────────────────────────────────────────────────────────────────
# Maximum JSONL entries in decisions.jsonl before rotation.
DECISION_LOG_MAX_ENTRIES=5000

# ── Cost Tracking (USD per million tokens — update if pricing changes) ─────────
COST_PER_MTK_IN=3.0
COST_PER_MTK_OUT=15.0
